# ============================================================================
# Appointment Prep AI Agent - Environment Configuration
# ============================================================================
#
# This file contains configuration settings for the application.
# Copy this file to .env and customize the values.
#
# IMPORTANT: Never commit your .env file to version control!
# The .env file should contain your actual API keys and secrets.
#
# ============================================================================

# ----------------------------------------------------------------------------
# OpenRouter API Configuration (LLM)
# ----------------------------------------------------------------------------
#
# The application uses OpenRouter API for LLM-powered message generation.
# OpenRouter provides access to multiple free models with automatic fallback.
#
# To get your OpenRouter API key:
# 1. Go to https://openrouter.ai/
# 2. Sign up for a free account
# 3. Go to Keys section in your dashboard
# 4. Create a new API key
# 5. Paste the API key below
#
# The application uses a 4-tier fallback system with free models:
# 1. nvidia/nemotron-3-super-120b-a12b:free (Primary - 120B parameters)
# 2. arcee-ai/trinity-large-preview:free (Fallback 1)
# 3. openai/gpt-oss-120b:free (Fallback 2 - 120B parameters)
# 4. nvidia/nemotron-3-nano-30b-a3b:free (Fallback 3 - 30B parameters)
#
# If all models fail or no API key is provided, the application will
# automatically fall back to template-based message generation.
#
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ----------------------------------------------------------------------------
# Geoapify Places API Configuration (Hospital Lookup)
# ----------------------------------------------------------------------------
#
# For real-time hospital search with location data from OpenStreetMap.
# Free tier: ~3,000 requests/day
#
# To get your Geoapify API key:
# 1. Go to https://www.geoapify.com/
# 2. Sign up for a free account
# 3. Go to your dashboard
# 4. Create a new API key (select "Places" API)
# 5. Paste the API key below
#
# Geoapify provides:
# - 500+ place categories (including hospitals)
# - Location-based search with radius
# - Built on OpenStreetMap data
# - Production-ready structured JSON
# - Data storage allowed (important!)
#
# If not configured, the application uses mock hospital data.
#
GEOAPIFY_API_KEY=

# ----------------------------------------------------------------------------
# Twilio SMS Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending SMS appointment reminders and confirmations.
# If not configured, the application logs SMS to console (mock mode).
#
# To get Twilio credentials:
# 1. Go to https://www.twilio.com/
# 2. Sign up for a free trial account
# 3. Get your Account SID and Auth Token from the dashboard
# 4. Get a Twilio phone number
# 5. Paste the credentials below
#
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# Hospital Notification Configuration (Optional)
# ----------------------------------------------------------------------------
#
# Email address to receive notifications when new appointments are booked.
# If not configured, hospital notifications will not be sent.
#
# HOSPITAL_NOTIFY_EMAIL=appointments@hospital.com

# ----------------------------------------------------------------------------
# Google Calendar Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For appointment scheduling integration with Google Calendar.
# If not configured, the application uses mock calendar mode.
#
# To set up Google Calendar:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google Calendar API
# 4. Create a service account
# 5. Download the JSON key file
# 6. Set the path to the JSON file below
# 7. Share your calendar with the service account email
#
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account-key.json

# ----------------------------------------------------------------------------
# Gmail API Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending email prep instructions and confirmations via Gmail.
# If not configured, the application falls back to SendGrid or mock mode.
#
# To set up Gmail API:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Gmail API
# 4. Create a service account
# 5. Download the JSON key file
# 6. Set the path to the JSON file below
# 7. Set your sender email address
#
# GMAIL_SENDER_ADDRESS=your-email@gmail.com
# GMAIL_OAUTH_CREDENTIALS_JSON=path/to/service-account-key.json

# ----------------------------------------------------------------------------
# SendGrid Email Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending email prep instructions and confirmations.
# If not configured, the application logs emails to console (mock mode).
#
# To get SendGrid API key:
# 1. Go to https://sendgrid.com/
# 2. Sign up for a free account
# 3. Create an API key in Settings > API Keys
# 4. Paste the API key below
# 5. Set your verified sender email
#
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# Fast2SMS Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending SMS appointment reminders and confirmations (India only).
# If not configured, the application falls back to Twilio or mock mode.
#
# To get Fast2SMS API key:
# 1. Go to https://www.fast2sms.com/
# 2. Sign up for a free account
# 3. Get your API key from the dashboard
# 4. Paste the API key below
#
# FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ----------------------------------------------------------------------------
# Twilio SMS Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending SMS appointment reminders and confirmations.
# If not configured, the application logs SMS to console (mock mode).
#
# To get Twilio credentials:
# 1. Go to https://www.twilio.com/
# 2. Sign up for a free trial account
# 3. Get your Account SID and Auth Token from the dashboard
# 4. Get a Twilio phone number
# 5. Paste the credentials below
#
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# Hospital Notification Configuration (Optional)
# ----------------------------------------------------------------------------
#
# Email address to receive notifications when new appointments are booked.
# If not configured, hospital notifications will not be sent.
#
# HOSPITAL_NOTIFY_EMAIL=appointments@hospital.com

# ----------------------------------------------------------------------------
# Flask Configuration (Optional)
# ----------------------------------------------------------------------------
#
# SECRET_KEY is used for session management and security features.
# For production, generate a secure random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# For local development, the default value is sufficient.
#
# SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# Database Configuration (Optional)
# ----------------------------------------------------------------------------
#
# By default, the application uses SQLite with the database file at:
#   data/appointments.db
#
# You can customize the database path if needed:
#
# DATABASE_PATH=data/appointments.db

# ----------------------------------------------------------------------------
# Application Configuration (Optional)
# ----------------------------------------------------------------------------
#
# Uncomment and modify these settings if needed:
#
# FLASK_ENV=development
# FLASK_DEBUG=True
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
