# ============================================================================
# Appointment Prep AI Agent - Environment Configuration
# ============================================================================
#
# This file contains configuration settings for the application.
# Copy this file to .env and customize the values.
#
# IMPORTANT: Never commit your .env file to version control!
# The .env file should contain your actual API keys and secrets.
#
# ============================================================================

# ----------------------------------------------------------------------------
# OpenRouter API Configuration (Optional - FREE MODEL)
# ----------------------------------------------------------------------------
#
# The application uses OpenRouter with FREE models and 4-tier automatic fallback.
# Fallback Chain (all free):
# 1. google/gemma-4-31b-it:free (Primary - 31B parameters)
# 2. google/gemma-4-26b-a4b-it:free (Fallback 1 - 26B parameters)
# 3. nvidia/nemotron-3-super-120b-a12b:free (Fallback 2 - 120B parameters)
# 4. meta-llama/llama-3.3-70b-instruct:free (Fallback 3 - 70B parameters)
# 5. Template-based responses (Final fallback - keyword matching)
#
# If no API key is provided, the application will use template-based messages.
#
# To get a FREE API key:
# 1. Go to https://openrouter.ai/keys
# 2. Sign up with your email or GitHub
# 3. Create a new API key (free tier, no credit card needed)
# 4. Copy the key (starts with "sk-or-v1-")
# 5. Paste it below (replace the placeholder text)
#
# Example: OPENROUTER_API_KEY=sk-or-v1-abc123xyz789...
#
# Note: The application works perfectly fine WITHOUT an API key.
# Template fallback mode generates clear, professional messages.
# The free model has NO COSTS - unlimited usage for free tier.
#
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ----------------------------------------------------------------------------
# Google Calendar Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For appointment scheduling integration with Google Calendar.
# If not configured, the application uses mock calendar mode.
#
# To set up Google Calendar:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google Calendar API
# 4. Create a service account
# 5. Download the JSON key file
# 6. Set the path to the JSON file below
# 7. Share your calendar with the service account email
#
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account-key.json

# ----------------------------------------------------------------------------
# Twilio SMS Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending SMS appointment reminders and confirmations.
# If not configured, the application logs SMS to console (mock mode).
#
# To get Twilio credentials:
# 1. Go to https://www.twilio.com/
# 2. Sign up for a free trial account
# 3. Get your Account SID and Auth Token from the dashboard
# 4. Get a Twilio phone number
# 5. Paste the credentials below
#
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# ----------------------------------------------------------------------------
# SendGrid Email Configuration (Optional)
# ----------------------------------------------------------------------------
#
# For sending email prep instructions and confirmations.
# If not configured, the application logs emails to console (mock mode).
#
# To get SendGrid API key:
# 1. Go to https://sendgrid.com/
# 2. Sign up for a free account
# 3. Create an API key in Settings > API Keys
# 4. Paste the API key below
# 5. Set your verified sender email
#
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# Flask Configuration (Optional)
# ----------------------------------------------------------------------------
#
# SECRET_KEY is used for session management and security features.
# For production, generate a secure random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# For local development, the default value is sufficient.
#
# SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# Database Configuration (Optional)
# ----------------------------------------------------------------------------
#
# By default, the application uses SQLite with the database file at:
#   data/appointments.db
#
# You can customize the database path if needed:
#
# DATABASE_PATH=data/appointments.db

# ----------------------------------------------------------------------------
# Application Configuration (Optional)
# ----------------------------------------------------------------------------
#
# Uncomment and modify these settings if needed:
#
# FLASK_ENV=development
# FLASK_DEBUG=True
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
