# ============================================================================
# Appointment Prep AI Agent - Environment Configuration
# ============================================================================
#
# This file contains configuration settings for the application.
# Copy this file to .env and customize the values.
#
# IMPORTANT: Never commit your .env file to version control!
# The .env file should contain your actual API keys and secrets.
#
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI API Configuration (Optional)
# ----------------------------------------------------------------------------
#
# The application can use OpenAI's API to rewrite messages in a friendly tone.
# If no API key is provided, the application will use template-based messages.
#
# To get an API key:
# 1. Go to https://platform.openai.com/api-keys
# 2. Sign up or log in to your OpenAI account
# 3. Create a new API key
# 4. Copy the key (starts with "sk-" or "sk-proj-")
# 5. Paste it below (replace the placeholder text)
#
# Example: OPENAI_API_KEY=sk-proj-abc123xyz789...
#
# Note: The application works perfectly fine WITHOUT an API key.
# Template fallback mode generates clear, professional messages.
# If the API key is invalid or missing, the system automatically falls back to template mode.
#
OPENAI_API_KEY=your_api_key_here

# ----------------------------------------------------------------------------
# Flask Configuration (Optional)
# ----------------------------------------------------------------------------
#
# SECRET_KEY is used for session management and security features.
# For production, generate a secure random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# For local development, the default value is sufficient.
#
# SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# Database Configuration (Optional)
# ----------------------------------------------------------------------------
#
# By default, the application uses SQLite with the database file at:
#   data/appointments.db
#
# You can customize the database path if needed:
#
# DATABASE_PATH=data/appointments.db

# ----------------------------------------------------------------------------
# Application Configuration (Optional)
# ----------------------------------------------------------------------------
#
# Uncomment and modify these settings if needed:
#
# FLASK_ENV=development
# FLASK_DEBUG=True
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
